{
  "name": "stakeflow-frontend",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://stakeflow-backend.railway.app"
  },
  "functions": {
    "app/api/**/*.js": {
      "maxDuration": 30
    }
  }
}